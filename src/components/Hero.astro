---
import { profile } from "@/data/profile";
---

<section class="hero" data-section="hero" aria-labelledby="hero-title">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="hero-location">{profile.location}</p>
      <h1 id="hero-title">{profile.name}</h1>
      <div class="hero-role">
        <p>{profile.title}</p>
        <span>{profile.subtitle}</span>
      </div>
      <p class="hero-value">{profile.value}</p>
      <ul class="tag-list" aria-label="Domaines clés">
        {profile.tags.map((tag) => <li>{tag}</li>)}
      </ul>
      <div class="hero-actions" aria-label="Actions principales">
        <a class="button button-primary" href="#projets" data-cta="hero-projects">
          Voir les projets
        </a>
        <a class="button button-secondary" href="#contact" data-cta="hero-contact">
          Me contacter
        </a>
      </div>
    </div>

    <aside class="hero-panel" aria-label="Résumé rapide">
      <div class="portrait-frame">
        <img
          src={profile.portrait}
          alt="Portrait de Julien Bonavita"
          width="900"
          height="900"
          decoding="async"
          fetchpriority="high"
        />
      </div>
      <div class="availability">
        <span>Disponible pour échanger</span>
        <p>{profile.status}</p>
      </div>
    </aside>
  </div>
</section>
