---
import { skills } from "@/data/profile";
import SectionHeader from "@/components/SectionHeader.astro";
---

<section id="competences" class="section section-skills" data-section="skills">
  <div class="section-inner">
    <SectionHeader
      label="Compétences"
      title="Ce que je sais mettre en œuvre."
      description="Des compétences groupées par usage, sans catalogue inutile."
    />
    <div class="skill-matrix">
      {skills.map((group) => (
        <article class="skill-group">
          <h3>{group.title}</h3>
          <p>{group.solved}</p>
          <ul>
            {group.tools.map((tool) => <li>{tool}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
