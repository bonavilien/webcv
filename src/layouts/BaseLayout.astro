---
import "../styles/global.css";
import { profile, seo } from "@/data/profile";

type Props = {
  title?: string;
  description?: string;
};

const title = Astro.props.title ?? seo.title;
const description = Astro.props.description ?? seo.description;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.title,
  email: profile.email,
  url: canonical.toString(),
  sameAs: [profile.linkedin],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Bordeaux",
    addressCountry: "FR",
  },
  alumniOf: [
    "Audencia SciencesCom",
    "University of North Florida",
    "Nantes Université",
  ],
  knowsAbout: [
    "Marketing communication",
    "Content strategy",
    "SEO",
    "Media planning",
    "Generative AI",
    "AI workflows",
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={seo.keywords.join(", ")} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#contenu">Aller au contenu</a>
    <header class="site-header">
      <nav class="nav-shell" aria-label="Navigation principale">
        <a class="brand-mark" href="#top" aria-label="Retour en haut">JB</a>
        <div class="nav-links">
          <a href="#projets">Projets</a>
          <a href="#experience">Parcours</a>
          <a href="#contact">Contact</a>
        </div>
      </nav>
    </header>
    <main id="contenu">
      <slot />
    </main>
  </body>
</html>
