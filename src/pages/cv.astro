---
import { profile } from "@/data/profile";

const pdfHref = "/cv-julien-bonavita.pdf";

const kedgeBullets = [
  "Construction et déploiement de plans de communication multicanaux pour Parcoursup, concours, admissibles, salons et JPO.",
  "Pilotage de plans médias pour les programmes Post-Bac et PGE : briefs, contenus sponsorisés, vidéos, insertions et bilans.",
  "Production de contenus de conversion : pages programmes, brochures, articles SEO, emailings, marketing automation, quiz, vidéos et supports terrain.",
  "Optimisation SEO des contenus programmes et travail avec les équipes programmes, commerciales, digitales, RP, social media, vidéo, graphisme et partenaires.",
  "Référent IA au sein de l'équipe content : veille, bonnes pratiques, cadrage de prompts et usages appliqués à la communication.",
];

const experiences = [
  {
    title: "Content Manager - Programmes, acquisition & plans médias",
    organization: "KEDGE Business School",
    period: "Sept. 2022 - aujourd'hui",
    location: "Bordeaux, hybride",
    intro:
      "Communication de programmes à fort enjeu de recrutement : Programme Grande École, KEDGE Bachelor, International BBA, EBP International, concours et admissibles.",
    bullets: kedgeBullets,
  },
  {
    title: "Chargé des relations média",
    organization: "KEDGE Business School",
    period: "Fév. 2022 - janv. 2023",
    location: "Bordeaux",
    bullets: [
      "Rédaction et diffusion de communiqués, dossiers de presse et éléments de langage.",
      "Organisation d'événements RP : conférences, voyages de presse et rencontres journalistes.",
      "Développement des relations médias, suivi de la couverture presse et mise à jour des outils RP.",
    ],
  },
  {
    title: "Responsable marketing et communication",
    organization: "Aïoli Digital",
    period: "Août 2021 - nov. 2021",
    location: "Les Sables-d'Olonne",
    bullets: [
      "Direction de l'équipe communication et pilotage des partenaires externes.",
      "Supervision des plannings, suivi des KPI et hausse de la qualité des rendus.",
      "Rationalisation des campagnes, optimisation du ROI et développement de partenariats influenceurs.",
    ],
  },
  {
    title: "Chargé de communication & marketing",
    organization: "Greek Boys Choice Foods",
    period: "Juil. 2019 - mars 2020",
    location: "Tarpon Springs, Floride, USA",
    bullets: [
      "Création de supports promotionnels print et digitaux : flyers, newsletters, étiquettes et contenus web.",
      "Actions marketing B2B, contenus web et campagnes email via Mailchimp en environnement anglophone.",
    ],
  },
  {
    title: "Assistant chargé de relations presse",
    organization: "Warning Up",
    period: "Mars 2018 - août 2018",
    location: "Paris",
    bullets: [
      "Gestion des relations médias, rédaction de communiqués et contenus éditoriaux, suivi des retombées presse.",
    ],
  },
];

const highlights = [
  "Plans médias concours pilotés pour plus de 250 000 euros.",
  "Brochures, pages web, emailings, vidéos, supports salons et contenus admissibles.",
  "Optimisation SEO de pages programmes et contenus à enjeu de recrutement.",
  "Anglais bilingue : TOEIC 990/990, TOEFL 105/120.",
];

const skills = [
  {
    title: "Contenu & communication",
    items: ["Stratégie éditoriale", "Rédaction web", "Brochures", "Scripts vidéo", "Newsletters", "Éléments de langage"],
  },
  {
    title: "SEO & acquisition",
    items: ["SEO éditorial", "Pages programmes", "Reporting", "Plans médias", "Contenus sponsorisés", "Analyse de performance"],
  },
  {
    title: "IA & outils",
    items: ["ChatGPT", "Claude", "Cursor", "Codex CLI", "Prompts IA", "Workflows"],
  },
  {
    title: "Tech & environnements",
    items: ["Astro", "CMS", "Linux", "Docker", "Self-hosting", "Outils web"],
  },
];

const education = [
  "Master Communication - Audencia SciencesCom, Nantes, 2020",
  "Semestre à l'étranger - University of North Florida, Jacksonville, USA, 2018",
  "Licence Langue et Culture Étrangère - Université de Nantes, 2016",
  "Cabin Crew Attestation - Aeroschool, Nantes, 2015",
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CV Julien Bonavita | Marketing, Content, SEO & IA</title>
    <meta
      name="description"
      content="CV HTML de Julien Bonavita, chef de projet marketing et communication à Bordeaux : content, SEO, acquisition, plans médias et IA générative."
    />
    <link rel="canonical" href={new URL("/cv/", Astro.site ?? Astro.url.origin)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <main class="cv-page" aria-label="CV Julien Bonavita">
      <header class="cv-header">
        <div class="identity">
          <img src="/images/portrait.webp" alt="Portrait de Julien Bonavita" class="cv-photo" />
          <div>
            <h1>Julien Bonavita</h1>
            <p class="headline">
              Chef de projet marketing & communication | Content, SEO, acquisition, plans médias & IA générative
            </p>
          </div>
        </div>
        <address class="contact">
          <a href={`mailto:${profile.email}`}>{profile.email}</a>
          <a href={profile.linkedin}>linkedin.com/in/julienbonavita</a>
          <span>Bordeaux / Talence</span>
        </address>
        <nav class="screen-actions" aria-label="Actions CV">
          <a href="/" class="ghost-link">Retour au site</a>
          <a href={pdfHref} class="download-link" download>Télécharger le PDF A4</a>
        </nav>
      </header>

      <section class="cv-section summary-section" aria-labelledby="profil-title">
        <h2 id="profil-title">Profil</h2>
        <p class="summary">
          Professionnel de la communication basé à Bordeaux, je transforme des enjeux business en dispositifs éditoriaux clairs, utiles et mesurables. Chez KEDGE Business School, je pilote des contenus et plans de communication pour des programmes à fort enjeu de recrutement, avec une approche orientée acquisition, SEO, reporting et usages IA.
        </p>
      </section>

      <section class="cv-section proof-strip" aria-labelledby="preuves-title">
        <h2 id="preuves-title">Réalisations clés</h2>
        <ul>
          {highlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </section>

      <div class="cv-grid">
        <section class="main-column" aria-labelledby="experience-title">
          <h2 id="experience-title">Expérience professionnelle</h2>
          <div class="experience-list">
            {experiences.map((experience) => (
              <article class="experience">
                <header>
                  <div>
                    <h3>{experience.title}</h3>
                    <p>{experience.organization}</p>
                  </div>
                  <p class="meta">{experience.period}<br />{experience.location}</p>
                </header>
                {experience.intro && <p class="intro">{experience.intro}</p>}
                <ul>
                  {experience.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <aside class="side-column" aria-label="Compétences, formation et langues">
          <section class="cv-section">
            <h2>Compétences</h2>
            <div class="skill-list">
              {skills.map((group) => (
                <section>
                  <h3>{group.title}</h3>
                  <p>{group.items.join(" · ")}</p>
                </section>
              ))}
            </div>
          </section>

          <section class="cv-section">
            <h2>Formation</h2>
            <ul class="compact-list">
              {education.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="cv-section">
            <h2>Langues & intérêts</h2>
            <p>
              Français natif. Anglais bilingue. Culture tech, IA, course à pied, photographie, aviation.
            </p>
          </section>
        </aside>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    --cv-bg: oklch(0.975 0.008 305);
    --cv-paper: oklch(1 0 0);
    --cv-ink: oklch(0.17 0.035 305);
    --cv-muted: oklch(0.34 0.035 305);
    --cv-line: oklch(0.84 0.025 305);
    --cv-primary: oklch(0.2 0.08 306);
    --cv-accent: oklch(0.54 0.19 285);
    --cv-soft: oklch(0.955 0.025 304);
    --cv-on-dark: oklch(0.985 0 0);
    --font-display: "Aptos Display", "Segoe UI Variable Display", "Arial Narrow", sans-serif;
    --font:
      Manrope, Aptos, "Segoe UI", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      Arial, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    color: var(--cv-ink);
    background: var(--cv-bg);
    font-family: var(--font);
    font-size: 1rem;
    line-height: 1.55;
    font-kerning: normal;
  }

  a {
    color: inherit;
    text-underline-offset: 0.18em;
  }

  h1,
  h2,
  h3,
  p,
  ul {
    margin: 0;
  }

  ul {
    padding: 0;
  }

  li {
    margin-left: 1.1rem;
    padding-left: 0.1rem;
  }

  .screen-actions {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .screen-actions a {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 0.9rem;
    border-radius: 8px;
    font-size: 0.92rem;
    font-weight: 760;
    text-decoration: none;
  }

  .ghost-link {
    color: var(--cv-primary);
    border: 1px solid var(--cv-line);
    background: var(--cv-paper);
  }

  .download-link {
    color: var(--cv-on-dark);
    background: var(--cv-primary);
  }

  .cv-page {
    width: min(100% - 28px, 880px);
    margin: 0 auto;
    padding: 1.25rem 0 3rem;
    background: var(--cv-paper);
  }

  .cv-header {
    padding: 1.2rem 0 1.35rem;
    border-bottom: 2px solid var(--cv-primary);
  }

  .identity {
    min-width: 0;
    display: grid;
    grid-template-columns: 78px minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
  }

  .cv-photo {
    width: 78px;
    aspect-ratio: 1;
    display: block;
    object-fit: cover;
    object-position: 50% 17%;
    border-radius: 9px;
    background: var(--cv-paper);
    border: 1px solid var(--cv-line);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 11vw, 3.15rem);
    line-height: 0.92;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .headline {
    max-width: 58ch;
    margin-top: 0.55rem;
    font-size: 1rem;
    font-weight: 760;
    line-height: 1.25;
    text-wrap: pretty;
  }

  .summary {
    max-width: 66ch;
    color: var(--cv-muted);
  }

  .contact {
    margin-top: 1rem;
    padding: 0;
    display: grid;
    gap: 0.25rem;
    color: var(--cv-ink);
    font-style: normal;
    font-size: 0.96rem;
    font-weight: 650;
  }

  .contact a {
    overflow-wrap: anywhere;
    text-decoration: none;
  }

  .summary-section {
    margin-top: 1.35rem;
  }

  .proof-strip {
    margin-top: 1.45rem;
    padding: 1.05rem 0;
    border-top: 1px solid var(--cv-line);
    border-bottom: 1px solid var(--cv-line);
  }

  .proof-strip h2 {
    color: var(--cv-primary);
  }

  .proof-strip ul {
    margin-top: 0.7rem;
    display: grid;
    gap: 0.45rem;
  }

  .proof-strip li {
    margin-left: 1rem;
    color: var(--cv-ink);
    font-weight: 700;
  }

  .cv-grid {
    margin-top: 1.55rem;
    display: grid;
    gap: 1.65rem;
  }

  h2 {
    font-family: var(--font-display);
    color: var(--cv-primary);
    font-size: 0.86rem;
    font-weight: 820;
    text-transform: uppercase;
    letter-spacing: 0.045em;
  }

  h3 {
    font-family: var(--font-display);
    font-size: 1.13rem;
    line-height: 1.16;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .experience-list {
    margin-top: 0.8rem;
    display: grid;
    gap: 1rem;
  }

  .experience {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--cv-line);
  }

  .experience:last-child {
    border-bottom: 0;
  }

  .experience header {
    display: grid;
    gap: 0.35rem;
  }

  .experience header p:not(.meta) {
    margin-top: 0.12rem;
    color: var(--cv-muted);
    font-weight: 760;
  }

  .meta {
    color: var(--cv-accent);
    font-size: 0.92rem;
    font-weight: 780;
  }

  .intro {
    max-width: 68ch;
    margin-top: 0.55rem;
    color: var(--cv-muted);
  }

  .experience ul,
  .compact-list {
    margin-top: 0.55rem;
    display: grid;
    gap: 0.35rem;
  }

  .side-column {
    display: grid;
    gap: 1.35rem;
    align-content: start;
  }

  .cv-section {
    min-width: 0;
  }

  .cv-section h2 + * {
    margin-top: 0.65rem;
  }

  .skill-list {
    display: grid;
    gap: 0.65rem;
  }

  .skill-list section {
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--cv-line);
  }

  .skill-list h3 {
    margin-bottom: 0.2rem;
    font-size: 1rem;
  }

  .skill-list p,
  .cv-section p {
    color: var(--cv-muted);
  }

  @media (max-width: 480px) {
    .cv-page {
      width: min(100% - 18px, 620px);
      padding-top: 0.7rem;
    }

    .cv-header {
      padding-top: 0.75rem;
    }

    .identity {
      grid-template-columns: 56px minmax(0, 1fr);
      gap: 0.75rem;
    }

    .cv-photo {
      width: 56px;
    }

    h1 {
      font-size: clamp(2rem, 10vw, 2.55rem);
    }

    .headline {
      font-size: 0.88rem;
      line-height: 1.18;
    }

    .contact {
      font-size: 0.9rem;
    }

    .screen-actions {
      margin-top: 0.85rem;
    }

    .screen-actions a {
      flex: 1 1 150px;
      font-size: 0.82rem;
    }
  }

  @media (min-width: 760px) {
    body {
      background: var(--cv-bg);
    }

    .cv-page {
      padding-top: 2rem;
    }

    .cv-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(220px, 280px);
      gap: 2rem;
      align-items: start;
    }

    .identity {
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 1.25rem;
    }

    .cv-photo {
      width: 96px;
    }

    .contact {
      margin-top: 0;
      justify-self: end;
      max-width: 280px;
      text-align: right;
    }

    .screen-actions {
      grid-column: 1 / -1;
      justify-content: flex-end;
      margin-top: 0.2rem;
    }

    .summary-section {
      display: grid;
      grid-template-columns: 120px minmax(0, 1fr);
      gap: 1.5rem;
      align-items: start;
    }

    .proof-strip ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem 1.6rem;
    }

    .cv-grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(260px, 0.72fr);
      gap: 2rem;
      align-items: start;
    }

    .experience header {
      grid-template-columns: minmax(0, 1fr) 170px;
      gap: 1rem;
    }

    .meta {
      text-align: right;
    }
  }

  @page {
    size: A4;
    margin: 0;
  }

  @media print {
    body {
      background: white;
      font-size: 8.35pt;
      line-height: 1.25;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .screen-actions {
      display: none;
    }

    .cv-page {
      width: 210mm;
      min-height: auto;
      margin: 0;
      padding: 9mm;
      background: white;
      border: 0;
      border-radius: 0;
    }

    .cv-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 50mm;
      gap: 5mm;
      align-items: start;
      padding: 0 0 3.4mm;
      border-bottom: 2px solid var(--cv-primary);
    }

    .identity {
      grid-template-columns: 24mm minmax(0, 1fr);
      gap: 4mm;
    }

    .cv-photo {
      width: 24mm;
      border-radius: 2mm;
    }

    h1 {
      font-size: 23pt;
      line-height: 0.92;
    }

    .headline {
      margin-top: 1mm;
      font-size: 8.2pt;
      line-height: 1.2;
      max-width: 54ch;
    }

    .summary {
      margin-top: 0;
      max-width: 70ch;
    }

    .contact {
      margin-top: 0;
      padding: 2.3mm;
      display: grid;
      gap: 1mm;
      color: var(--cv-on-dark);
      background: var(--cv-primary);
      border-radius: 2mm;
      font-size: 7.25pt;
      text-align: left;
    }

    .contact a {
      text-decoration: none;
    }

    .summary-section {
      margin-top: 3mm;
      display: grid;
      grid-template-columns: 24mm minmax(0, 1fr);
      gap: 4mm;
    }

    .proof-strip {
      margin-top: 3mm;
      padding: 2.3mm 0;
    }

    .proof-strip h2 {
      font-size: 7pt;
    }

    .proof-strip ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65mm 3mm;
    }

    .cv-grid {
      margin-top: 3mm;
      display: grid;
      grid-template-columns: minmax(0, 1.58fr) 48mm;
      gap: 5mm;
    }

    h2 {
      font-size: 7.25pt;
    }

    h3 {
      font-size: 8pt;
    }

    .experience-list {
      margin-top: 1.5mm;
      gap: 1.15mm;
    }

    .experience {
      padding-bottom: 1.15mm;
      break-inside: avoid;
    }

    .experience header {
      grid-template-columns: minmax(0, 1fr) 25mm;
      gap: 2mm;
    }

    .experience header p:not(.meta) {
      margin-top: 0.35mm;
    }

    .meta {
      font-size: 7pt;
      text-align: right;
    }

    .experience ul,
    .compact-list {
      margin-top: 0.85mm;
      gap: 0.52mm;
    }

    .intro {
      margin-top: 0.75mm;
    }

    .side-column {
      gap: 1.7mm;
    }

    .skill-list {
      gap: 1mm;
    }

    .skill-list section {
      padding: 0 0 1mm;
      background: transparent;
      border-bottom: 1px solid var(--cv-line);
    }

    .skill-list h3 {
      margin-bottom: 0.45mm;
      font-size: 7.25pt;
    }

    .experience li,
    .compact-list li {
      margin-left: 2.3mm;
      padding-left: 0.4mm;
    }
  }
</style>
